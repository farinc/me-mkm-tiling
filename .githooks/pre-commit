#!/bin/sh
# Keep python/me_mkm/_me_mkm/__init__.pyi in sync with the Rust API.
#
# When a commit touches any .rs file, regenerate the type stub and stage it, so
# signatures/docstrings in the .pyi never drift from the source. Skips entirely
# for commits that don't touch Rust, so Python-only commits stay fast.
set -e

# Only act when a Rust source is staged.
if ! git diff --cached --name-only --diff-filter=ACM | grep -q '\.rs$'; then
    exit 0
fi

if ! command -v cargo >/dev/null 2>&1; then
    echo "pre-commit: cargo not found — skipping stub regeneration (stubs may be stale)." >&2
    exit 0
fi

# Prefer the project venv interpreter; it knows where python3xx.dll lives.
if [ -x ".venv/Scripts/python.exe" ]; then
    PY=".venv/Scripts/python.exe"
elif [ -x ".venv/bin/python" ]; then
    PY=".venv/bin/python"
else
    PY="python"
fi

echo "pre-commit: Rust changed — regenerating type stubs..."
"$PY" scripts/regen_stubs.py

# Stage the (possibly updated) stub; a no-op if regeneration changed nothing.
git add python/me_mkm/_me_mkm/__init__.pyi
